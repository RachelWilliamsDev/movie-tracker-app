// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WatchSource {
  NETFLIX
  DISNEY_PLUS
  PRIME_VIDEO
  OTHER
}

/// User intent for a title: Watching, Completed, or Want to Watch (product labels in app code).
enum WatchStatus {
  WATCHING
  COMPLETED
  WANT_TO_WATCH
}

enum ProfileVisibility {
  PUBLIC
  PRIVATE
}

/// Feed-ready social actions (best-effort writes from product flows).
enum ActivityEventType {
  WATCH_COMPLETED
  RATED
}

/// Unified feed row: activity-derived posts today; share posts later (MEM-85).
enum PostType {
  ACTIVITY
  SHARE
}

enum PostMediaKind {
  MOVIE
  TV
}

/// Approval-ready follow state scaffold (workflow handled in later tickets).
enum FollowApprovalStatus {
  APPROVED
  PENDING
}

model User {
  id                String                  @id @default(cuid())
  email             String                  @unique
  /// Canonical social handle; normalized lowercase on write. Null only until onboarding (FEAT-127/129).
  /// FEAT-136: public discovery APIs require a username; run `npm run fe136:backfill` then `fe136:check` for ops.
  username          String?                 @unique
  name              String?
  password          String
  profileVisibility ProfileVisibility       @default(PUBLIC)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  watches           UserWatch[]
  following         UserFollow[]            @relation("UserFollowFollower")
  followers         UserFollow[]            @relation("UserFollowFollowing")
  tvEpisodeProgress UserTvEpisodeProgress[]
  ratings           UserRating[]
  activityEvents    UserActivityEvent[]
  posts             Post[]
  postComments      PostComment[]
  postLikes         PostLike[]
}

/// Append-only activity log for a future social feed; metadata holds TMDB keys + display hints.
model UserActivityEvent {
  id        String            @id @default(cuid())
  actorId   String
  actor     User              @relation(fields: [actorId], references: [id], onDelete: Cascade)
  type      ActivityEventType
  metadata  Json
  createdAt DateTime          @default(now())
  post      Post?

  @@index([actorId, createdAt(sort: Desc)])
}

/// Social feed persistence. Activity rows are backfilled from `UserActivityEvent` via `sourceActivityEventId`.
model Post {
  id                    String         @id @default(cuid())
  userId                String
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                  PostType
  content               String?
  mediaKind             PostMediaKind
  tmdbId                Int
  metadata              Json
  createdAt             DateTime
  sourceActivityEventId String?        @unique
  sourceActivityEvent   UserActivityEvent? @relation(fields: [sourceActivityEventId], references: [id], onDelete: SetNull)
  comments              PostComment[]
  likes                 PostLike[]

  @@index([userId, createdAt(sort: Desc)])
}

/// One like per user per post (MEM-87). Counts derived from rows (no separate counter).
model PostLike {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([postId])
}

/// Flat comments on a feed post (MEM-88); plain text only, max length enforced in API.
model PostComment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.VarChar(2000)
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
}

/// TMDB-backed watch record; one row per user + title (movie or TV).
model UserWatch {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentId   Int
  mediaType   String
  /// Existing rows before this column map to COMPLETED via DB default (see FEAT-026).
  watchStatus WatchStatus  @default(COMPLETED)
  watchSource WatchSource?
  createdAt   DateTime     @default(now())

  @@unique([userId, contentId, mediaType])
}

/// Current episode per TV season; one row per user + show + season.
model UserTvEpisodeProgress {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentId     Int
  mediaType     String
  seasonNumber  Int
  episodeNumber Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, contentId, mediaType, seasonNumber])
}

/// User score for a movie or TV title (1–5). Independent of watch / episode progress.
model UserRating {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentId Int
  mediaType String
  rating    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, contentId, mediaType])
}

/// Follow relationship between users.
model UserFollow {
  id             String               @id @default(cuid())
  followerId     String
  followingId    String
  approvalStatus FollowApprovalStatus @default(APPROVED)
  createdAt      DateTime             @default(now())
  follower       User                 @relation("UserFollowFollower", fields: [followerId], references: [id], onDelete: Cascade)
  following      User                 @relation("UserFollowFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}
