# Copy to `.env` in the project root (never commit `.env`):
#   cp .env.example .env
#
# Local dev: `npm run dev` serves on http://127.0.0.1:3000 — keep NEXTAUTH_URL in sync
# to avoid NextAuth NEXTAUTH_URL warnings in the console.

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME"

TMDB_API_KEY=

# Where to Watch (MEM-96 / MEM-103): ISO 3166-1 alpha-2 region for TMDB watch/providers (server-only). Default GB.
# Caching TTL is code-defined (86400s); see docs/where-to-watch.md for TMDB paths and QA checklist.
# WATCH_PROVIDERS_REGION=GB

# Generate e.g. `openssl rand -base64 32`
NEXTAUTH_SECRET=

# Required for NextAuth; must match the URL you use in the browser during dev.
NEXTAUTH_URL=http://127.0.0.1:3000

# E2E (Playwright, MEM-78): optional overrides; defaults match `prisma/seed.ts`
# E2E_DISCOVER_VIEWER_EMAIL=e2e.discover.viewer@example.test
# E2E_DISCOVER_VIEWER_PASSWORD=E2eDiscover_Smoke1!

# Optional: `npm run db:seed:fake` — synthetic users (default 100, password SeedFake100!)
# SEED_FAKE_USERS_COUNT=100
# SEED_FAKE_USERS_PASSWORD=SeedFake100!

# Optional: `npm run qa:fake-users:activity` — sign in each fake user, set watches, follow @meelux (Docker: QA_BASE_URL=http://127.0.0.1:3000)
# QA_BASE_URL=http://127.0.0.1:3000
# QA_FAKE_USER_COUNT=100
# QA_FOLLOW_COUNT=10
# QA_FOLLOW_USERNAME=meelux
