# Copy to `.env` in the project root (never commit `.env`):
#   cp .env.example .env
#
# Local dev: `npm run dev` serves on http://127.0.0.1:3000 — keep NEXTAUTH_URL in sync
# to avoid NextAuth NEXTAUTH_URL warnings in the console.

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME"

TMDB_API_KEY=

# Generate e.g. `openssl rand -base64 32`
NEXTAUTH_SECRET=

# Required for NextAuth; must match the URL you use in the browser during dev.
NEXTAUTH_URL=http://127.0.0.1:3000

# E2E (Playwright, MEM-78): optional overrides; defaults match `prisma/seed.ts`
# E2E_DISCOVER_VIEWER_EMAIL=e2e.discover.viewer@example.test
# E2E_DISCOVER_VIEWER_PASSWORD=E2eDiscover_Smoke1!
